{
  "name": "plyrs",
  "private": true,
  "scripts": {
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "format": "oxfmt --ignore-path=.gitignore --ignore-path=.oxfmtignore .",
    "format:check": "oxfmt --check --ignore-path=.gitignore --ignore-path=.oxfmtignore .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r --filter '!@plyrs/e2e' run test"
  },
  "devDependencies": {
    "oxfmt": "0.58.0",
    "oxlint": "^1.73.0",
    "wrangler": "catalog:"
  },
  "packageManager": "pnpm@10.26.1"
}
